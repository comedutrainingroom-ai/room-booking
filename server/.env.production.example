# Server production environment
PORT=5000

# MongoDB inside docker-compose
MONGO_URI=mongodb://mongo:27017/room_booking_v2

# Public URL that users actually open in the browser
# Example: https://room-booking.cs.kmutnb.ac.th
CLIENT_URL=https://your-domain.kmutnb.ac.th

# Allowed email domains
ALLOWED_DOMAINS=kmutnb.ac.th,email.kmutnb.ac.th

# Admin PIN for admin registration / unlock flow
ADMIN_PIN=change-this-pin
ADMIN_PIN_TOKEN_SECRET=replace-with-a-long-random-secret
ADMIN_PIN_TOKEN_TTL_MINUTES=480

# Outbound email settings
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Firebase Admin credentials
# Choose one approach:
# 1) Set FIREBASE_SERVICE_ACCOUNT_JSON to the full JSON string
# 2) Set FIREBASE_SERVICE_ACCOUNT_JSON_BASE64 to a base64 encoded JSON string
# 3) Mount a file into /run/secrets/firebase/serviceAccountKey.json
#    and set GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase/serviceAccountKey.json
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase/serviceAccountKey.json
