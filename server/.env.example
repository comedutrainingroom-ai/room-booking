# Server Configuration
PORT=5000

# MongoDB (use 'mongo' as host when running in Docker)
MONGO_USERNAME=<your-mongo-username>
MONGO_PASSWORD=<your-mongo-password>
MONGO_URI=mongodb://mongo:27017/room_booking_v2

# Client URL for CORS (must match the domain users access)
CLIENT_URL=https://your-domain.kmutnb.ac.th

# Firebase Admin credentials
# Recommended for production:
# - FIREBASE_SERVICE_ACCOUNT_JSON=<full JSON string>
# or
# - FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=<base64 encoded JSON>
#
# File-based fallback is still supported:
# - GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase/serviceAccountKey.json

# Allowed email domains for registration
ALLOWED_DOMAINS=kmutnb.ac.th,email.kmutnb.ac.th

# Admin PIN for admin registration
ADMIN_PIN=<your-admin-pin>
ADMIN_PIN_TOKEN_SECRET=<long-random-secret-for-admin-pin-sessions>
ADMIN_PIN_TOKEN_TTL_MINUTES=480

# Email (Gmail App Password)
EMAIL_USER=<your-email@gmail.com>
EMAIL_PASS=<your-gmail-app-password>
